NODE_ENV=production
PORT=4000

# PostgreSQL — reste sur localhost, ne jamais exposer sur le réseau
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fms_mining
DB_USER=fms_user
DB_PASSWORD=CHANGER_EN_PRODUCTION
DB_POOL_MIN=2
DB_POOL_MAX=20

# JWT — générer avec : openssl rand -hex 64
JWT_SECRET=CHANGER_EN_PRODUCTION_MINIMUM_64_CARACTERES
JWT_EXPIRES_IN=8h

# CORS — ajouter l'IP LAN du serveur et des postes clients
# Ex: http://192.168.1.100:4000,http://192.168.1.101
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4000

# GPS Simulation — true en développement, false en production
ENABLE_GPS_SIMULATION=false
GPS_UPDATE_INTERVAL_MS=5000
